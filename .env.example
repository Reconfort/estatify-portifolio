# =============================================================================
# ESTATIFY — ENVIRONMENT TEMPLATE
# Copy to `.env` (or `.env.local` for Next apps) and fill in real values.
# All vars are validated at boot by @estatify/config (zod, fail-fast).
# Never commit a real .env — only this .example file is tracked.
# =============================================================================

# Runtime mode: development | test | production
NODE_ENV=development

# ---- Server-only (never exposed to the browser) ----------------------------
# Primary datastore connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/estatify
# Base URL the apps use to reach the NestJS API.
API_URL=http://localhost:3333
# Session signing secret. REQUIRED when NODE_ENV=production (min 16 chars).
AUTH_SECRET=change-me-to-a-long-random-string

# ---- Client-safe (inlined into the browser bundle; must be NEXT_PUBLIC_*) --
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3333

# ---- Escape hatch ----------------------------------------------------------
# Set to "true" to skip validation (e.g. Docker image build with no env yet).
# SKIP_ENV_VALIDATION=true
