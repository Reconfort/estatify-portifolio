# =============================================================================
# ESTATIFY — ENVIRONMENT TEMPLATE
# Copy to `.env` (root, for API + Prisma) and fill in real values.
# Validated at boot by @estatify/config (zod, fail-fast). Only this .example is tracked.
# =============================================================================

# Runtime mode: development | test | production
NODE_ENV=development
PORT=4000

# ---- Database (multi-tenant, RLS-enforced) ---------------------------------
# APP role: NON-superuser, subject to RLS. The running API uses this.
DATABASE_URL=postgresql://estatify_app:estatify_app@localhost:5432/estatify?schema=public
# OWNER role: used ONLY by `prisma migrate`/`db push` for DDL. Never by the API at runtime.
DATABASE_DIRECT_URL=postgresql://postgres:postgres@localhost:5432/estatify?schema=public

# ---- Redis (tenant cache, rate-limit buckets) ------------------------------
REDIS_URL=redis://localhost:6379

# ---- JWT / sessions --------------------------------------------------------
# Access token signing secret (min 32 chars). Rotate via kid in a later pass.
JWT_ACCESS_SECRET=dev-only-change-me-to-a-32+char-random-secret
JWT_ACCESS_TTL=15m
# Refresh tokens are opaque + hashed at rest; this is their lifetime in days.
REFRESH_TTL_DAYS=30
# Cookie scope so workspace/platform subdomains share the refresh cookie.
# Dev: leave blank (host-only on localhost). Prod: .estatify.com
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ---- Email (verification + password reset) ---------------------------------
# dev = smtp (Mailpit); prod = sendgrid | resend | smtp
MAIL_PROVIDER=smtp
MAIL_FROM="Estatify <no-reply@estatify.com>"
SMTP_HOST=localhost
SMTP_PORT=1025
# SENDGRID_API_KEY=
# RESEND_API_KEY=

# ---- App URLs (link generation in emails, CORS) ----------------------------
APP_WORKSPACE_URL=http://localhost:3000
APP_PLATFORM_URL=http://localhost:3100
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
# Cross-app navigation (Marketing ↔ Workspace). Prod: https://estatify.africa / https://workspace.estatify.africa
NEXT_PUBLIC_WORKSPACE_URL=http://localhost:3000
NEXT_PUBLIC_MARKETING_URL=http://localhost:3200
NEXT_PUBLIC_PLATFORM_URL=http://localhost:3100

NEXT_PUBLIC_PLATFORM_URL=http://localhost:3100

# ---- Object storage (tenant media — MinIO local, R2/S3 prod) -----------------
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=estatify-tenant
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=minioadmin
STORAGE_PUBLIC_URL=http://localhost:9000/estatify-tenant
STORAGE_REGION=us-east-1
STORAGE_FORCE_PATH_STYLE=true

# ---- Escape hatch ----------------------------------------------------------
# SKIP_ENV_VALIDATION=true
