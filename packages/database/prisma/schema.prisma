// Estatify data model — Milestone 2 (Auth & Multi-Tenancy).
// See docs/MILESTONE-2-AUTH-MULTITENANCY.md §2.
//
// Isolation contract: every TENANT-SCOPED table carries `tenantId` and is guarded
// by a Postgres RLS policy (see prisma/rls.sql). Identity tables (User, Session,
// token tables) are GLOBAL — a user authenticates before a tenant is known — and
// are protected by application-level ownership checks, not RLS.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  // App role (non-superuser) — subject to RLS. Used by the running API.
  url        = env("DATABASE_URL")
  // Owner role — used ONLY by `prisma migrate` / `db push` for DDL.
  directUrl  = env("DATABASE_DIRECT_URL")
  extensions = [citext]
}

enum TenantStatus {
  active
  suspended
  pending
}

enum MembershipRole {
  owner
  admin
  agent
  member
}

enum PlatformRole {
  none
  support
  superadmin
}

enum TenantPlan {
  free
  starter
  growth
  scale
  enterprise
}

enum StaffDepartment {
  engineering
  support
  finance
  customer_success
  marketing
  operations
  executive
}

enum StaffStatus {
  active
  disabled
  invited
}

enum UserStatus {
  active
  suspended
}

/// The isolation root. One Tenant == one Agency (M2-D1). Not itself RLS-scoped
/// (it has no parent tenant); access is gated by membership at the app layer.
model Tenant {
  id           String       @id @default(uuid()) @db.Uuid
  slug         String       @unique // -> {slug}.estatify.com
  status       TenantStatus @default(pending)
  plan         TenantPlan   @default(free)
  lastActiveAt DateTime?
  deletedAt    DateTime? // soft delete (platform admin)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  agency       Agency?
  memberships  Membership[]
  invites      Invite[]
  preference   TenantPreference?

  @@index([status])
  @@index([plan])
  @@index([deletedAt])
}

/// The tenant's public brand/profile. RLS-scoped.
model Agency {
  id            String               @id @default(uuid()) @db.Uuid
  tenantId      String               @unique @db.Uuid
  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  primaryDomain String?              @unique // custom domain, nullable
  brand         Json? // legacy — superseded by AgencyConfiguration.draftBrand
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  configuration AgencyConfiguration?
  mediaAssets   MediaAsset[]

  @@index([tenantId])
}

enum MediaCategory {
  logo
  favicon
  hero
  company
  gallery
  document
}

/// Draft + published website configuration (one row per agency). RLS-scoped.
model AgencyConfiguration {
  id       String @id @default(uuid()) @db.Uuid
  agencyId String @unique @db.Uuid
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  tenantId String @db.Uuid

  draftProfile   Json @default("{}")
  draftBrand     Json @default("{}")
  draftWebsite   Json @default("{}")
  draftSeo       Json @default("{}")
  draftComposition Json @default("{}")

  publishedProfile Json @default("{}")
  publishedBrand   Json @default("{}")
  publishedWebsite Json @default("{}")
  publishedSeo     Json @default("{}")
  publishedComposition Json @default("{}")

  templateId  String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
}

/// Tenant-uploaded media stored in object storage. RLS-scoped.
model MediaAsset {
  id         String        @id @default(uuid()) @db.Uuid
  tenantId   String        @db.Uuid
  agencyId   String        @db.Uuid
  agency     Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  category   MediaCategory
  storageKey String
  url        String
  fileName   String
  mimeType   String
  fileSize   Int
  width      Int?
  height     Int?
  uploadedBy String        @db.Uuid
  createdAt  DateTime      @default(now())

  @@index([tenantId])
  @@index([agencyId])
  @@index([category])
}

/// Tenant onboarding goals selected after signup (RLS-scoped). One row per tenant.
model TenantPreference {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @unique @db.Uuid
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Array of goal keys, e.g. ["list_properties", "capture_leads"]
  goals       Json      @default("[]")
  completedAt DateTime?
  completedBy String?   @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
}

/// Global identity. No tenantId — the ONLY bridge to a tenant is Membership.
model User {
  id                  String               @id @default(uuid()) @db.Uuid
  email               String               @unique @db.Citext
  passwordHash        String
  emailVerified       Boolean              @default(false)
  isPlatformStaff     Boolean              @default(false)
  platformRole        PlatformRole         @default(none)
  /// Universal kill switch. Suspending flips this and bumps tokenVersion.
  status              UserStatus           @default(active)
  /// Session/token version. Every access token embeds the value at issue time;
  /// bumping it invalidates ALL of the user's live access tokens immediately.
  tokenVersion        Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  memberships         Membership[]
  sessions            Session[]
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  staffProfile        StaffProfile?
}

// ===========================================================================
// PLATFORM RBAC & STAFF (Access Management)
// These are GLOBAL platform tables — NOT tenant-scoped, so no RLS policy.
// Access is gated by the platform authorization layer (PermissionsGuard).
// ===========================================================================

/// A single, code-defined capability (e.g. "tenant.view"). Read-only in product;
/// the catalog is synced from @estatify/types PERMISSION_CATALOG on seed.
model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique // "tenant.view"
  module      String // "Tenants"
  action      String // "view"
  description String
  createdAt   DateTime         @default(now())
  roles       RolePermission[]

  @@index([module])
}

/// A named bundle of permissions assignable to platform staff.
model Role {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique
  description String           @default("")
  isSystem    Boolean          @default(false) // system roles (Super Admin) can't be deleted
  deletedAt   DateTime? // soft delete
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  staff       StaffProfile[]
}

/// Join: role ↔ permission (many-to-many).
model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

/// Estatify employee profile, attached to a global User (isPlatformStaff=true).
model StaffProfile {
  id               String          @id @default(uuid()) @db.Uuid
  userId           String          @unique @db.Uuid
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName         String
  avatarUrl        String?
  department       StaffDepartment @default(operations)
  roleId           String?         @db.Uuid
  role             Role?           @relation(fields: [roleId], references: [id])
  status           StaffStatus     @default(active)
  twoFactorEnabled Boolean         @default(false)
  lastLoginAt      DateTime?
  deletedAt        DateTime? // soft delete
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([roleId])
  @@index([department])
  @@index([status])
  @@index([deletedAt])
}

/// Binds a user to a tenant with a role. RLS-scoped.
model Membership {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @db.Uuid
  tenantId  String         @db.Uuid
  role      MembershipRole @default(member)
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
}

/// Refresh-token sessions. `familyId` groups a rotation chain so reuse detection
/// can revoke the whole family. Global (keyed by user), not RLS-scoped.
model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  tenantId         String?   @db.Uuid // active tenant bound to this session
  refreshTokenHash String    @unique // sha-256 of the opaque refresh token
  familyId         String    @db.Uuid
  userAgent        String?
  ip               String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
}

model VerificationToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Pending invitation to join a tenant. RLS-scoped.
model Invite {
  id         String         @id @default(uuid()) @db.Uuid
  tenantId   String         @db.Uuid
  email      String         @db.Citext
  role       MembershipRole @default(member)
  tokenHash  String         @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime       @default(now())
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
}
