{
  "name": "estatify",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "graph": "nx graph",
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:marketing": "nx dev marketing",
    "dev:workspace": "nx dev workspace",
    "dev:platform": "nx dev platform",
    "dev:sites": "nx dev sites",
    "dev:api": "nx serve api",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "motion": "^12.0.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.0",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^0.460.0",
    "react-hook-form": "^7.54.0",
    "zod": "^3.24.0",
    "@hookform/resolvers": "^3.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "nx": "latest",
    "@nx/eslint": "latest",
    "@nx/eslint-plugin": "latest",
    "@nx/js": "latest",
    "@nx/next": "latest",
    "@nx/nest": "latest",
    "prettier": "^3",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
